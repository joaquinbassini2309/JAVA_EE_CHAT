<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.1"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd">

    <!-- Unidad de persistencia para WildFly -->
    <persistence-unit name="chatPU" transaction-type="JTA">
        
        <!-- Provider de Hibernate (puede ser omitido, Wildfly lo detecta automáticamente) -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        
        <!-- Data Source JTA configurado en WildFly -->
        <!-- El script de setup configura este data source para apuntar a la BD 'chat'
             /subsystem=datasources/data-source=ChatDS:add(
                 jndi-name=java:/ChatDS,
                 driver-name=postgresql,
                 connection-url=jdbc:postgresql://localhost:5432/chat,
                 user-name=postgres,
                 password=tu_password)
        -->
        <jta-data-source>java:/ChatDS</jta-data-source>
        
        <!-- Entidades mapeadas explícitamente -->
        <class>chat.clases.Usuario</class>
        <class>chat.clases.Conversacion</class>
        <class>chat.clases.Mensaje</class>
        <class>chat.clases.Participante</class>

        <properties>
            <!-- Dialecto de Hibernate para PostgreSQL -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            
            <!-- SQL Logging (cambiar a false en producción) -->
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
            
            <!-- Estrategia de creación/actualización de esquema:
                 create: Crea tablas nuevas (borra existentes)
                 update: Actualiza esquema sin perder datos (RECOMENDADO)
                 validate: Solo valida sin hacer cambios
                 create-drop: Crea al iniciar, elimina al cerrar (SOLO DESARROLLO)
            -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            
            <!-- Configuración de conexiones -->
            <property name="hibernate.jdbc.batch_size" value="20"/>
            <property name="hibernate.jdbc.fetch_size" value="50"/>
            
            <!-- Nombres de columnas y tablas -->
            <property name="hibernate.physical_naming_strategy" 
                     value="org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl"/>
            <property name="hibernate.implicit_naming_strategy" 
                     value="org.hibernate.boot.model.naming.ImplicitNamingStrategyLegacyJpaImpl"/>
        </properties>
    </persistence-unit>
</persistence>

