<module version="4">
  <!-- Removed nested content roots that belonged to submodules (CapaNegocio etc.).
       Keeping this .iml minimal avoids IntelliJ assigning source roots from child modules
       into the aggregator module 'chat-empresarial', which caused the "belongs to
       content of nested module" errors. After this change, re-import the Maven project
       (or restart IntelliJ) so each module gets its correct content roots from pom.xml.
  -->
</module>